# ===== BASE DE DATOS =====
DATABASE_URL="mysql://root:@localhost:3306/sarui_studio"
MONGODB_URI="mongodb://localhost:27017/sarui_logs"

# ===== SERVIDOR API =====
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ===== JWT =====
JWT_SECRET=sarui_super_secret_cambia_en_produccion_min_32chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ===== MERCADOPAGO =====
# Obtener en: https://www.mercadopago.com.mx/settings/account/credentials
MP_ACCESS_TOKEN=TEST-xxxx
MP_PUBLIC_KEY=TEST-xxxx
# Obtener del panel MP → Tu negocio → Configuración → Webhooks → Clave secreta
MP_WEBHOOK_SECRET=

# ===== FRONTEND =====
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
